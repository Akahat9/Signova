{
  "name": "signova-frontend",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "main": "electron/main.cjs",
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.178.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test:rules": "node --test firebase-rules.test.cjs",
    "desktop": "npm run build && electron .",
    "desktop:dev": "concurrently -k \"npm start\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^36.9.5",
    "postcss": "^8.5.15",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.19",
    "wait-on": "^8.0.3"
  }
}
