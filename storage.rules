rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function verifiedUser() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function safeImage() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function safeMedia() {
      return request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('(video|audio)/(mp4|mpeg|webm|ogg|wav)');
    }

    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow create, update: if verifiedUser()
        && request.auth.uid == userId
        && safeImage();
      allow delete: if verifiedUser() && request.auth.uid == userId;
    }

    match /users/{userId}/private/{fileName} {
      allow read: if verifiedUser() && request.auth.uid == userId;
      allow create, update: if verifiedUser()
        && request.auth.uid == userId
        && (safeImage() || safeMedia());
      allow delete: if verifiedUser() && request.auth.uid == userId;
    }

    match /community/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if verifiedUser()
        && request.auth.uid == userId
        && (safeImage() || safeMedia());
      allow delete: if verifiedUser() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
