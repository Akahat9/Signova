SIGNOVA_AI_HOST=127.0.0.1
SIGNOVA_AI_PORT=8000
SIGNOVA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SIGNOVA_MAX_REQUEST_BYTES=5242880
# Must match the backend SIGNOVA_AI_SERVICE_TOKEN outside localhost.
SIGNOVA_AI_SERVICE_TOKEN=replace_with_a_long_random_service_token
SIGNOVA_MAX_CONCURRENT_INFERENCES=2
SIGNOVA_INFERENCE_ACQUIRE_TIMEOUT=0.25
SIGNOVA_RTMW_ENABLED=1
SIGNOVA_RTMW_MODE=auto
SIGNOVA_RTMW_BACKEND=onnxruntime
SIGNOVA_RTMW_DEVICE=cuda
SIGNOVA_RTMW_SCORE_THRESHOLD=0.2
SIGNOVA_RTMW_SESSION_TTL=120
SIGNOVA_RTMW_BUFFER_SIZE=48
SIGNOVA_RTMW_MAX_SESSIONS=32
SIGNOVA_RTMW_MAX_PEOPLE=8
SIGNOVA_RTMW_MAX_FRAME_DIMENSION=1280
SIGNOVA_RTMW_SWITCH_MARGIN=0.08
SIGNOVA_RTMW_SWITCH_HOLD_MS=900
SIGNOVA_RTMW_MIN_ACTIVE_MS=1800
SIGNOVA_RTMW_ACTIVE_LOST_MS=1200
SIGNOVA_RTMW_ACTIVE_SCORE_MIN=0.28
SIGNOVA_RTMW_MULTI_PERSON_MOTION_MIN=0.003
SIGNOVA_RTMW_INITIAL_ACQUIRE_MS=400
