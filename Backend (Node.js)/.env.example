PORT=5000
SIGNOVA_AI_URL=http://127.0.0.1:8000
SIGNOVA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SIGNOVA_MAX_REQUEST_BYTES=5242880
SIGNOVA_AI_TIMEOUT_MS=15000
SIGNOVA_MAX_AI_RESPONSE_BYTES=2097152
# Generate one strong random value and set the same value in the AI service.
SIGNOVA_AI_SERVICE_TOKEN=replace_with_a_long_random_service_token
SIGNOVA_AI_REQUESTS_PER_MINUTE=30
SIGNOVA_SENTENCE_REQUESTS_PER_MINUTE=60
SIGNOVA_RATE_LIMIT_MAX_BUCKETS=20000
# Optional until username/phone identity login is enabled.
SIGNOVA_IDENTITY_HMAC_SECRET=replace_with_at_least_32_random_characters
SIGNOVA_IDENTITY_RATE_LIMIT=20
FIREBASE_PROJECT_ID=signova-6e929
# Optional until username login/recovery is enabled; email/password auth runs in the Firebase frontend SDK.
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
# Use GOOGLE_APPLICATION_CREDENTIALS locally; use workload identity in production.
MONGODB_URI=mongodb+srv://akshatsharma3coder_db_user:<db_password>@cluster0.f6feycf.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DATABASE=signova
# Optional local fallback when the network/router DNS resolver rejects SRV queries.
MONGODB_DNS_SERVERS=
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_WAIT_QUEUE_TIMEOUT_MS=5000
MONGODB_FEEDBACK_RETENTION_DAYS=90
